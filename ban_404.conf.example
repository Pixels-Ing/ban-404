# /etc/ban_404.conf — LOCAL per-server configuration (NOT versioned).
# /etc/ban_404.conf — configuration LOCALE par serveur (NON versionnée).
# /etc/ban_404.conf — LOKALE Konfiguration pro Server (NICHT versioniert).
# /etc/ban_404.conf — configuración LOCAL por servidor (NO versionada).
# /etc/ban_404.conf — configurazione LOCALE per server (NON versionata).

# Repo raw URL (no trailing slash), used by the self-updater.
# URL raw du dépôt (sans slash final), utilisée par le self-updater.
# Raw-URL des Repos (ohne abschließenden Schrägstrich), vom Self-Updater verwendet.
# URL raw del repositorio (sin barra final), usada por el self-updater.
# URL raw del repository (senza slash finale), usata dal self-updater.
REPO_RAW="https://raw.githubusercontent.com/Pixels-Ing/ban-404/main"

# IPs to NEVER ban (exact match, separated by | ).
# IP à ne JAMAIS bannir (correspondance exacte, séparées par | ).
# Niemals zu sperrende IPs (exakte Übereinstimmung, durch | getrennt).
# IP que NUNCA bloquear (coincidencia exacta, separadas por | ).
# IP da non bloccare MAI (corrispondenza esatta, separati da | ).
WHITELIST_IP="127.0.0.1"

# Messages language: en (default) | fr | de | es | it
# Langue des messages : en (défaut) | fr | de | es | it
# Sprache der Meldungen: en (Standard) | fr | de | es | it
# Idioma de los mensajes: en (por defecto) | fr | de | es | it
# Lingua dei messaggi: en (predefinito) | fr | de | es | it
#BAN404_LANG="en"

# --- Optional settings (uncomment to override, see help for details) ---
# --- Réglages optionnels (décommenter pour surcharger, voir l'aide pour les détails) ---
# --- Optionale Einstellungen (zum Überschreiben auskommentieren, Details siehe Hilfe) ---
# --- Ajustes opcionales (descomentar para sobrescribir, ver la ayuda para más detalles) ---
# --- Impostazioni opzionali (decommentare per sovrascrivere, vedere l'aiuto per i dettagli) ---
#WINDOW=7200
#BAN_TIMEOUT=172800
#TAIL_LINES=50000
#BAN_THRESHOLD=10
#HONEYPOT_SCORE=100
#HONEYPOT_BAN_TIMEOUT=604800
#POST_FLOOD_THRESHOLD=20
#RESOLVE_PTR=false
#PTR_TIMEOUT=2
# CRON_STEP: extra runs via a managed /etc/cron.d — empty = hourly only, 5-30 = every N min, auto = adaptive 5-60 min with attack sentinel.
# CRON_STEP : passages supplémentaires via un /etc/cron.d géré — vide = horaire seul, 5-30 = toutes les N min, auto = adaptatif 5-60 min avec sentinelle d'attaque.
# CRON_STEP: zusätzliche Läufe über ein verwaltetes /etc/cron.d — leer = nur stündlich, 5-30 = alle N min, auto = adaptiv 5-60 min mit Angriffswächter.
# CRON_STEP: ejecuciones adicionales vía un /etc/cron.d gestionado — vacío = solo horaria, 5-30 = cada N min, auto = adaptativo 5-60 min con centinela de ataques.
# CRON_STEP: esecuzioni aggiuntive via un /etc/cron.d gestito — vuoto = solo oraria, 5-30 = ogni N min, auto = adattivo 5-60 min con sentinella di attacco.
#CRON_STEP=""

# --- CIDR whitelist / subnets to NEVER ban (separated by | ) ---
# --- Whitelist CIDR / sous-réseaux à ne JAMAIS bannir (séparés par | ) ---
# --- CIDR-Whitelist / niemals zu sperrende Subnetze (durch | getrennt) ---
# --- Lista blanca CIDR / subredes que NUNCA bloquear (separadas por | ) ---
# --- Whitelist CIDR / sottoreti da non bloccare MAI (separate da | ) ---
#WHITELIST_CIDR="10.0.0.0/8|192.168.0.0/16"

# --- Vhosts to EXCLUDE from analysis (folder names under /var/www, separated by | ) ---
# --- Vhosts à EXCLURE de l'analyse (noms de dossier sous /var/www, séparés par | ) ---
# --- Von der Analyse auszuschließende Vhosts (Ordnernamen unter /var/www, durch | getrennt) ---
# --- Vhosts a EXCLUIR del análisis (nombres de carpeta en /var/www, separados por | ) ---
# --- Vhost da ESCLUDERE dall'analisi (nomi di cartella sotto /var/www, separati da | ) ---
#EXCLUDE_VHOSTS="staging.exemple.com|interne.exemple.com"

# --- Notifications (empty => disabled; messages in the BAN404_LANG language) ---
# --- Notifications (vides => désactivées ; messages dans la langue BAN404_LANG) ---
# --- Benachrichtigungen (leer => deaktiviert; Meldungen in der Sprache BAN404_LANG) ---
# --- Notificaciones (vacías => desactivadas; mensajes en el idioma BAN404_LANG) ---
# --- Notifiche (vuote => disattivate; messaggi nella lingua BAN404_LANG) ---
#SERVER_NICKNAME=""
#WEBHOOK_URL=""
#NOTIFY_EMAIL=""
#NOTIFY_FROM=""
#NOTIFY_MIN_BANS=1
#NOTIFY_BANS=false
#DAILY_SUMMARY=false

# --- Server vital signs (shown by diag/health and the daily summary; WARN thresholds) ---
# --- Signes vitaux du serveur (affichés par diag/health et le résumé quotidien ; seuils de WARN) ---
# --- Vitalwerte des Servers (angezeigt von diag/health und der täglichen Zusammenfassung; WARN-Schwellen) ---
# --- Constantes vitales del servidor (mostradas por diag/health y el resumen diario; umbrales de WARN) ---
# --- Segni vitali del server (mostrati da diag/health e dal riepilogo giornaliero; soglie di WARN) ---
#HEALTH_CHECKS=true
#HEALTH_LOAD_WARN=2
#HEALTH_MEM_WARN=10
#HEALTH_DISK_WARN=90
#HEALTH_MAILQ_WARN=50
#HEALTH_IO_WARN=25

# --- Detection patterns (awk regex) — ADVANCED: override only if you know what you are doing ---
# --- Motifs de détection (regex awk) — AVANCÉ : ne surcharger qu'en connaissance de cause ---
# --- Erkennungsmuster (awk-Regex) — FORTGESCHRITTEN: nur mit Sachkenntnis überschreiben ---
# --- Patrones de detección (regex awk) — AVANZADO: sobrescribir solo con conocimiento ---
# --- Pattern di rilevamento (regex awk) — AVANZATO: sovrascrivere solo con cognizione di causa ---
#HONEYPOT_PATTERN='\.env|wp-config\.php|phpmyadmin|config\.json|setup\.php|actuator|xmlrpc\.php'
#NOISE_PATTERN='\.(jpg|jpeg|png|gif|webp|ico|css|js|svg|woff2?|map)$|apple-touch-icon|favicon|browserconfig\.xml|mstile|autodiscover\.xml|sitemap\.xml|robots\.txt|ads\.txt|\.well-known/(security\.txt|pki-validation)'
# --- Monitoring/health-check host: a fixed endpoint (e.g. Uptime Kuma push /api/push/<token>) can 404 with no client fault — append it so its 404s never count as a flood; also whitelist the senders (WHITELIST_IP). ---
# --- Hôte de monitoring/health-check : un endpoint fixe (ex. push Uptime Kuma /api/push/<token>) peut renvoyer 404 sans faute du client — l'ajouter pour que ses 404 ne comptent jamais ; whitelister aussi les émetteurs (WHITELIST_IP). ---
# --- Monitoring-/Health-Check-Host: ein fester Endpunkt (z. B. Uptime-Kuma-Push /api/push/<token>) kann ohne Client-Fehler 404 liefern — anhängen, damit seine 404 nie zählen; zusätzlich die Absender per WHITELIST_IP absichern. ---
# --- Host de monitorización/health-check: un endpoint fijo (p. ej. push de Uptime Kuma /api/push/<token>) puede dar 404 sin culpa del cliente — añadirlo para que sus 404 nunca cuenten; y whitelist de los emisores (WHITELIST_IP). ---
# --- Host di monitoraggio/health-check: un endpoint fisso (es. push di Uptime Kuma /api/push/<token>) può dare 404 senza colpa del client — aggiungerlo perché i suoi 404 non contino mai; e whitelist dei mittenti (WHITELIST_IP). ---
# The conf is sourced AFTER the default, so this appends to it:
#NOISE_PATTERN="${NOISE_PATTERN}|^/api/push/"
# SECURITY_PATTERN: tested on the request for ANY HTTP status (not only 404); match = immediate ban.
# SECURITY_PATTERN : testé sur la requête QUEL QUE SOIT le statut HTTP (pas seulement 404) ; match = ban immédiat.
# SECURITY_PATTERN: auf die Anfrage bei JEDEM HTTP-Status geprüft (nicht nur 404); Treffer = sofortige Sperre.
# SECURITY_PATTERN: probado en la petición con CUALQUIER estado HTTP (no solo 404); coincidencia = bloqueo inmediato.
# SECURITY_PATTERN: testato sulla richiesta con QUALSIASI stato HTTP (non solo 404); corrispondenza = blocco immediato.
#SECURITY_PATTERN='etc(/|%2f)passwd|\.\./\.\.|%2e%2e%2f|\.\.%2f|%00|vendor/phpunit|eval-stdin\.php|union(\+|%20)select|information_schema|amp%3bamp%3b|resultsperpage=[^& ]*%3f|resultsperpage.*resultsperpage'
# POST_FLOOD_PATTERN: monitored POST paths; over POST_FLOOD_THRESHOLD hits in the window = ban (brute force).
# POST_FLOOD_PATTERN : chemins POST surveillés ; au-delà de POST_FLOOD_THRESHOLD dans la fenêtre = ban (brute force).
# POST_FLOOD_PATTERN: überwachte POST-Pfade; mehr als POST_FLOOD_THRESHOLD im Zeitfenster = Sperre (Brute-Force).
# POST_FLOOD_PATTERN: rutas POST vigiladas; superar POST_FLOOD_THRESHOLD en la ventana = bloqueo (fuerza bruta).
# POST_FLOOD_PATTERN: percorsi POST sorvegliati; oltre POST_FLOOD_THRESHOLD nella finestra = blocco (forza bruta).
#POST_FLOOD_PATTERN='wp-login\.php|xmlrpc\.php'
